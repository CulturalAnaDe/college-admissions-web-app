# Берем стабильную 22-ю версию Node.js на базе легкого дистрибутива Alpine Linux
FROM node:22-alpine

# Создаем рабочую папку внутри контейнера
WORKDIR /app

# Копируем файлы со списком зависимостей
COPY package*.json ./

# Устанавливаем библиотеки (включая Sequelize, Express и т.д.)
RUN npm install

# Копируем вообще весь код бэкенда (папки src, uploads, файлы .env, server.js)
COPY . .

# Открываем порт бэкенда (поменяй на свой, если у тебя в коде другой, например 5000 или 8080)
EXPOSE 3000

# Запускаем сервер через твой главный файл server.js
CMD ["node", "server.js"]